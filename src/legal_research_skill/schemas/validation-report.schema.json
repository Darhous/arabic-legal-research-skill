{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:arabic-legal-research-skill:validation-report:0.3.0",
  "title": "Arabic Legal Research Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_schema_version",
    "metadata",
    "input_identifier",
    "input_hash",
    "overall_status",
    "overall_decision",
    "validator_results",
    "findings",
    "counts_by_severity",
    "counts_by_status",
    "executed_validators",
    "skipped_validators",
    "allowed_output_claims",
    "prohibited_output_claims",
    "limitations"
  ],
  "properties": {
    "report_schema_version": { "const": "0.3.0" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "package_version", "deterministic"],
      "properties": {
        "tool": { "const": "legal_research_skill" },
        "package_version": { "type": "string" },
        "deterministic": { "type": "boolean" }
      }
    },
    "input_identifier": { "type": "string" },
    "input_hash": { "type": "string" },
    "overall_status": { "enum": ["pass", "fail", "warning", "skipped"] },
    "overall_decision": { "enum": ["PROCEED", "REVISE", "PAUSE", "FAIL"] },
    "validator_results": { "type": "array", "items": { "$ref": "#/$defs/validator_result" } },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "counts_by_severity": { "$ref": "#/$defs/counts" },
    "counts_by_status": { "$ref": "#/$defs/counts" },
    "executed_validators": { "type": "array", "items": { "type": "string" } },
    "skipped_validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator", "reason"],
        "properties": {
          "validator": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "allowed_output_claims": { "type": "array", "items": { "type": "string" } },
    "prohibited_output_claims": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "validator_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator", "version", "status", "decision", "findings", "skipped_reason", "limitations"],
      "properties": {
        "validator": { "type": "string" },
        "version": { "type": "string" },
        "status": { "enum": ["pass", "fail", "warning", "skipped"] },
        "decision": { "enum": ["PROCEED", "REVISE", "PAUSE", "FAIL"] },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "skipped_reason": { "type": ["string", "null"] },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "validator",
        "rule_id",
        "status",
        "decision",
        "severity",
        "message",
        "evidence",
        "affected_locations",
        "required_corrections",
        "verification_required",
        "task_memory_updates",
        "rerun_required",
        "limitations",
        "path",
        "related_ids",
        "code",
        "metadata"
      ],
      "properties": {
        "finding_id": { "type": "string" },
        "validator": { "type": "string" },
        "rule_id": { "type": "string" },
        "status": { "enum": ["pass", "fail", "warning", "skipped"] },
        "decision": { "enum": ["PROCEED", "REVISE", "PAUSE", "FAIL"] },
        "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
        "message": { "type": "string" },
        "evidence": { "type": "object" },
        "affected_locations": { "type": "array", "items": { "type": "string" } },
        "required_corrections": { "type": "array", "items": { "type": "string" } },
        "verification_required": { "type": "boolean" },
        "task_memory_updates": { "type": "array", "items": { "type": "string" } },
        "rerun_required": { "type": "boolean" },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "path": { "type": "string" },
        "related_ids": { "type": "array", "items": { "type": "string" } },
        "code": { "type": "string" },
        "metadata": { "type": "object" }
      }
    }
  }
}
